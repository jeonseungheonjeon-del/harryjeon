      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            " 야 컴퓨터! 1부터 30 사이에 숫자 하나를 골랐어, 맞춰봐!\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# for 을 사용해서 총 5번의 기회를 줍니다\n",
        "guessed_correctly = False # Flag to track if the number was guessed\n",
        "for chance in range(1, 100):\n",
        "  # 사용자의 입력을 받아서 변수의 저장합니다.\n",
        "  guess = int(input(f\"[{chance}번째 기회] 숫자를 입력하세요: \"))\n",
        "  # if 를 사용해서 정답인지, 업인지, 다운인지 판별합니다\n",
        "  if guess == secret_number:\n",
        "    print(f\"정답이야! {chance}번 만에 맞췄어. 너 구글러 소질 있는데?\")\n",
        "    guessed_correctly = True\n",
        "    break # Exit the loop if correct\n",
        "  elif guess < secret_number:\n",
        "    print(\"Up! 더 큰 숫자야.\")\n",
        "  else:\n",
        "    print(\"Down! 더 작은 숫자야\")\n",
        "\n",
        "# 5번의 기회를 다 쓰면 실행되는 코드 (또는 정답을 맞추지 못했을 경우)\n",
        "if not guessed_correctly:\n",
        "  print(f\"실패! 정답은 {secret_number}였어. 다음에 다시 도전해봐!\")"
      ],
